{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "sales", "support"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "preferences": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales lead",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "lost"] },
        "notes": { "type": "string" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Safari booking",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "tourId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid", "refunded"] },
        "totalAmount": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "packageDetails": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "tourId", "status", "paymentStatus", "totalAmount"]
    },
    "Tour": {
      "title": "Tour",
      "description": "Safari tour package",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "capacity": { "type": "number" },
        "availableSlots": { "type": "number" },
        "durationDays": { "type": "number" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "capacity", "availableSlots"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Customer complaint",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved"] },
        "assignedTo": { "type": "string" },
        "resolution": { "type": "string" },
        "satisfactionScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "description", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" },
    "/leads/{leadId}": { "schema": "Lead", "description": "Sales leads" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Bookings" },
    "/tours/{tourId}": { "schema": "Tour", "description": "Tour packages" },
    "/complaints/{complaintId}": { "schema": "Complaint", "description": "Complaints" }
  }
}
